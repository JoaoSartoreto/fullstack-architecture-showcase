# ==========================================
# Core API Environment Configuration Example
# ==========================================

# Execution Environment
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=postgres-core
DB_PORT=5432
DB_USER=user_core
DB_PASS=password_core
DB_NAME=core_db

# Security
JWT_SECRET=super_secret_showcase_key_2026
JWT_EXPIRATION=1h

# RabbitMQ Message Broker Configuration
RMQ_HOST=rabbitmq
RMQ_PORT=5672
RMQ_USER=guest
RMQ_PASS=guest

# Outbox & Distributed Auditing Configuration
OUTBOX_RELAY_CRON="*/5 * * * * *"
OUTBOX_SWEEP_CRON="0 3 * * *"
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=3
OUTBOX_RETENTION_DAYS=7

# System Initialization
# Set to 'true' to auto-provision initial admin users and catalog items
ENABLE_DB_SEED=true